# Chaves de Integração com o Supabase
# Renomeie este arquivo para .env e preencha com as credenciais do seu projeto.

# URL do seu projeto Supabase (disponível em Project Settings > API)
VITE_SUPABASE_URL=https://seu-projeto-id.supabase.co

# Chave pública anônima do Supabase (disponível em Project Settings > API)
VITE_SUPABASE_ANON_KEY=sua-chave-anon-publica-aqui
